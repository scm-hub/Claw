{
  "name": "workflow-engine",
  "version": "1.0.0",
  "description": "杭州鲜当家统一审批流引擎 - 全系统通用审批服务",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "node prisma/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "prisma": "^6.3.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
