# ============================================================
# 杭州鲜当家全品类食用菌综合管理平台 — 环境变量模板
# ============================================================
# 使用方式：复制此文件为 .env 并填写实际值
#   cp .env.example .env
# ============================================================

# ---------- 通用配置 ----------
NODE_ENV=development
TZ=Asia/Shanghai

# ---------- Portal 统一认证中心 (端口 4001) ----------
PORTAL_PORT=4001
PORTAL_DATABASE_URL=mysql://user:password@localhost:3306/portal_db
SSO_JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
SSO_JWT_EXPIRES_IN=7d

# ---------- HRMS 人力资源 (端口 4002) ----------
HRMS_PORT=4002
HRMS_DATABASE_URL=mysql://user:password@localhost:3306/hrms_db
HRMS_JWT_SECRET=change-me-to-another-random-secret

# ---------- SCM 供应链管理 (端口 4003) ----------
SCM_PORT=4003
SCM_DATABASE_URL=mysql://user:password@localhost:3306/scm_db
SCM_REDIS_URL=redis://localhost:6379
SCM_JWT_SECRET=change-me-to-a-third-random-secret

# ---------- AI 智能服务 (端口 4004) ----------
AI_PORT=4004
AI_API_KEY=your-ai-service-api-key

# ---------- MDM 主数据管理 (端口 4005) ----------
MDM_PORT=4005
MDM_DATABASE_URL=mysql://user:password@localhost:3306/mdm_db

# ---------- Workflow 审批引擎 (端口 4011) ----------
WORKFLOW_PORT=4011
WORKFLOW_DATABASE_URL=mysql://user:password@localhost:3306/workflow_db

# ---------- Gateway 统一网关 (端口 5174) ----------
GATEWAY_PORT=5174
