// 十四、冷链监控
// ============================================================

model Sensor {
  id            String    @id @default(cuid())
  sensorCode    String    @unique
  name          String
  warehouseId   String?
  zoneId        String?
  locationId    String?
  sensorType    String    @default("TEMP_HUMIDITY")
  protocol      String    @default("MQTT")
  deviceAddress String?
