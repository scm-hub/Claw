  @@map("fee_records")
}

/// 成本价计算历史记录（加权平均法，每天0:00和12:00自动计算）
model CostPriceRecord {
  id               String   @id @default(cuid())
  materialId       String   /// 物料ID
  materialName     String   /// 物料名称（冗余存储，方便历史查询）
  gradeId          String?  @map("grade_id") /// 等级ID（null表示不分等级的物料）
  gradeName        String?  /// 等级名称（冗余存储）
  // 期初
  beginningQty     Decimal  @default(0) @db.Decimal(12, 2) /// 期初数量
  beginningPrice   Decimal  @default(0) @db.Decimal(12, 4) /// 期初单价
  beginningAmount  Decimal  @default(0) @db.Decimal(12, 2) /// 期初金额 = 期初数量 × 期初单价
  // 入库
  inboundQty       Decimal  @default(0) @db.Decimal(12, 2) /// 入库总数量
  inboundAmount    Decimal  @default(0) @db.Decimal(12, 2) /// 入库总金额
  salesCostPrice   Decimal  @default(0) @db.Decimal(12, 4) /// 销售成本价 = 入库总金额 ÷ 入库总数量
  // 出库
  outboundQty      Decimal  @default(0) @db.Decimal(12, 2) /// 出库总数量
  outboundAmount   Decimal  @default(0) @db.Decimal(12, 2) /// 出库总金额
  // 损耗
  lossQty          Decimal  @default(0) @db.Decimal(12, 2) /// 最新盘点损耗数量（取最新一次盘点的|diffQty|）
  // 结存
  endingQty        Decimal  @default(0) @db.Decimal(12, 2) /// 结存数量 = 期初 + 入库 - 出库 - 损耗
  endingAmount     Decimal  @default(0) @db.Decimal(12, 2) /// 结存金额 = 期初金额 + 入库金额 - 出库金额
  costPrice        Decimal  @default(0) @db.Decimal(12, 4) /// 最终成本价 = 加权平均单价 + 费用合计
  weightedAvgPrice Decimal  @default(0) @db.Decimal(12, 4) /// 加权平均单价 = 结存金额 ÷ 结存数量
  // 费用（保留兼容）
  feesTotal        Decimal  @default(0) @db.Decimal(12, 2) /// 启用的各类费用合计
  feesDetail       Json     /// 费用明细 [{feeName, amount}, ...]
  // 时间范围
  periodStart      DateTime? /// 本次计算时间段起点（上次计算时间）
  periodEnd        DateTime  @default(now()) /// 本次计算时间段终点（当前计算时间）
  calculatedAt     DateTime  @default(now()) /// 计算时间

  // 关联的盘点明细（本次计算用到的盘点损耗项）
  stockTakeItems   StockTakeItem[]

  @@index([materialId, gradeId, calculatedAt])
  @@index([calculatedAt])
  @@map("cost_price_records")
}

/// 产品损耗计算历史记录（每天0:00和12:00自动计算）
model ProductLossRecord {
  id               String   @id @default(cuid())
  materialId       String   /// 物料ID
  materialName     String   /// 物料名称（冗余存储）
  // 期初
  beginningQty     Decimal  @default(0) @db.Decimal(12, 2) /// 期初数量
  // 入库
  inboundQty       Decimal  @default(0) @db.Decimal(12, 2) /// 入库总数量
  // 出库
  outboundQty      Decimal  @default(0) @db.Decimal(12, 2) /// 出库总数量
  // 应存 = 期初 + 入库 - 出库
  expectedQty      Decimal  @default(0) @db.Decimal(12, 2) /// 应存数量
  // 实存 = 当前库存
  actualQty        Decimal  @default(0) @db.Decimal(12, 2) /// 实存数量（盘点值）
  // 损耗
  lossQty          Decimal  @default(0) @db.Decimal(12, 2) /// 损耗数量 = 应存 - 实存
  lossRate         Decimal  @default(0) @db.Decimal(5, 2) /// 损耗率(%) = 损耗数量 / (期初+入库) × 100
  cumulativeLossRate Decimal  @default(0) @db.Decimal(5, 2) /// 累计损耗率(%)，按月周期(29号-次月28号)计算
  lossAmount       Decimal  @default(0) @db.Decimal(12, 2) /// 损耗金额 = 损耗数量 × 加权平均单价
  weightedAvgPrice Decimal  @default(0) @db.Decimal(12, 4) /// 加权平均单价（取自同期成本价记录）
  // 时间范围
  periodStart      DateTime? /// 计算时间段起点
  periodEnd        DateTime  @default(now()) /// 计算时间段终点
  calculatedAt     DateTime  @default(now()) /// 计算时间

  @@index([materialId, calculatedAt])
  @@index([calculatedAt])
  @@map("product_loss_records")
}

