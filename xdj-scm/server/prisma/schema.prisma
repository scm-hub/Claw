  destAddress  String                      // 目的地详细地址
  destLng      String?                     // 目的地经度
  destLat      String?                     // 目的地纬度
  distance     Decimal? @db.Decimal(10,2)  // 驾车距离（公里）
  status       String   @default("ACTIVE") // ACTIVE / INACTIVE
  remark       String?                     // 备注
