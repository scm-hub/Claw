  totalCost           Decimal   @default(0) @db.Decimal(12, 2)
  status              String    @default("PLANNED")
  optimizedPath       Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  logisticsProvider LogisticsProvider? @relation(fields: [logisticsProviderId], references: [id])
  waybills          Waybill[]

  @@index([routeDate])
  @@index([status])
  @@map("delivery_routes")
}

model FreightSettlement {
  id                  String    @id @default(cuid())
  settlementNo        String    @unique
  logisticsProviderId String
  periodStart         DateTime
  periodEnd           DateTime
  totalFreight        Decimal   @default(0) @db.Decimal(14, 2)
  settledAmount       Decimal   @default(0) @db.Decimal(14, 2)
  balance             Decimal   @default(0) @db.Decimal(14, 2)
  waybillIds          Json?
  status              String    @default("PENDING")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  logisticsProvider LogisticsProvider @relation(fields: [logisticsProviderId], references: [id])

  @@index([logisticsProviderId])
  @@index([status])
  @@map("freight_settlements")
}

