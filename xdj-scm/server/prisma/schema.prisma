  material        Material       @relation(fields: [materialId], references: [id])

  @@unique([shippingOrderId, salesOrderItemId])
  @@index([shippingOrderId])
  @@map("shipping_order_items")
}

// 拼车智能建议
model MergeSuggestion {
  id              String    @id @default(cuid())
  suggestionNo    String    @unique                                    // 建议编号 MS20260706001
  sourceOrderIds  Json                                                   // 源发货单ID列表
  mergedOrderId   String?                                                // 合并后发货单ID
  totalWeight     Decimal?  @db.Decimal(10, 2)                          // 预估总重量(吨)
  totalVolume     Decimal?  @db.Decimal(10, 2)                          // 预估总体积(m³)
  totalKilometers Decimal?  @db.Decimal(10, 2)                          // 预估总里程
  estimatedCost   Decimal?  @db.Decimal(12, 2)                          // 预估运费
