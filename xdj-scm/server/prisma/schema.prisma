// 鲜当家食用菌供应链管理系统 — Prisma Schema
// 独立数据库 xdj_scm_db，与 HRMS/SCM 完全隔离

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 一、用户与认证
// ============================================================

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  employeeId   String?   @unique
  role         String    @default("EMPLOYEE")
  status       String    @default("ACTIVE")
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee              Employee?        @relation("UserEmployee", fields: [employeeId], references: [id])
  alertRecordsAsTarget  AlertRecord[]    @relation("AlertTargetUser")
  alertRecordsAsResolver AlertRecord[]   @relation("AlertResolver")
  notifications         Notification[]
  purchaserAssignments  PurchaserAssignment[]
  assignedPurchasePlans PurchasePlan[]       @relation("PlanAssignee")
  managedWarehouses     Warehouse[]          @relation("WarehouseManager")

  @@index([role])
  @@map("users")
}

// ============================================================
// 二、组织架构
// ============================================================

model Department {
  id         String   @id @default(cuid())
  name       String
  code       String?  @unique
  parentId   String?
  managerId  String?
  sortOrder  Int      @default(0)
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent        Department?  @relation("DeptParent", fields: [parentId], references: [id])
  children      Department[] @relation("DeptParent")
  manager       Employee?    @relation("DeptManager", fields: [managerId], references: [id])
  employees     Employee[]   @relation("DeptEmployees")
  customers     Customer[]
  purchasePlans PurchasePlan[]
  salesPlans    SalesPlan[]
  priceLists    PriceList[]

  @@index([parentId])
  @@map("departments")
}

model Employee {
  id           String   @id @default(cuid())
  globalId     String   @unique @default(cuid())  // 跨系统统一标识，SSO 匹配用
  empNo        String   @unique
  name         String
  departmentId String?
  position     String?
  phone        String?
  email        String?
  status       String   @default("ACTIVE")
  hireDate     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department           Department?         @relation("DeptEmployees", fields: [departmentId], references: [id])
  managedDepts         Department[]        @relation("DeptManager")
  user                 User?               @relation("UserEmployee")
  warehouses           Warehouse[]
  priceLists           PriceList[]         @relation("PriceListSalesRep")
  purchasePlanApprovals PurchasePlan[]     @relation("PurchasePlanApprover")
  salesPlanApprovals   SalesPlan[]         @relation("SalesPlanApprover")
  temperatureAlerts    TemperatureAlert[]

  // 业务关联
  salesCustomers     Customer[]          @relation("CustomerSalesRep")
  purchaseOrders     PurchaseOrder[]     @relation("PurchaseBuyer")
  purchaseReceipts   PurchaseReceipt[]   @relation("PurchaseInspector")
  salesOrders        SalesOrder[]        @relation("SalesOrderRep")
  approvedSalesOrders SalesOrder[]       @relation("SalesOrderApprover")
  salesPlans         SalesPlan[]         @relation("SalesPlanRep")
  purchasePlans      PurchasePlan[]      @relation("PurchasePlanCreator")
  stockMovements     StockMovement[]    @relation("StockMovementOperator")
  stockTakes         StockTake[]        @relation("StockTakeCreator")
  stockTakeItems     StockTakeItem[]    @relation("StockTakeCounter")
  batchTrackings     BatchTracking[]    @relation("BatchTrackingOperator")
  recallOrders       RecallOrder[]      @relation("RecallInitiator")
  recallApprovals    RecallOrder[]      @relation("RecallApprover")
  payments           Payment[]          @relation("PaymentOperator")
  barcodeRecords     BarcodeRecord[]    @relation("BarcodeOperator")
  supplierEvals      SupplierEvaluation[] @relation("SupplierEvalEvaluator")
  contracts          Contract[]         @relation("ContractCreator")
  approvalFlows      ApprovalFlow[]     @relation("ApprovalApplicant")
  approvalApprovals  ApprovalFlow[]     @relation("ApprovalApprover")
  afterSalesRecords  AfterSalesRecord[]

  @@index([departmentId])
  @@index([name])
  @@map("employees")
}

// ============================================================
// 三、仓库 + 库区 + 库位（WMS 三级结构）
// ============================================================

model Warehouse {
  id            String   @id @default(cuid())
  name          String
  code          String?  @unique
  address       String?
  managerId     String?
  warehouseManagerId String?
  isColdStorage Boolean  @default(false)
  isRemote      Boolean  @default(false)                 // 是否异地外仓
  transferLeadDays Int?                                    // 总部调拨至该仓所需天数（>0=可调拨外仓）
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  manager      Employee?          @relation(fields: [managerId], references: [id])
  warehouseManager User?           @relation("WarehouseManager", fields: [warehouseManagerId], references: [id])
  zones        WarehouseZone[]
  locations    WarehouseLocation[]
  inventory     Inventory[]
  stockMovements StockMovement[]
  stockTakes   StockTake[]
  stockLocks   StockLock[]
  sensors      Sensor[]
  purchaseOrders PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]
  salesOrders  SalesOrder[]
  shippingOrders ShippingOrder[]

  // 安全库存反向关系
  stockStandards     StockStandard[]
  stockLevels        StockLevel[]
  stockAlerts        StockAlert[]

  @@map("warehouses")
}

model WarehouseZone {
  id          String   @id @default(cuid())
  warehouseId String
  name        String
  code        String
  zoneType    String   @default("STORAGE")
  sortOrder   Int      @default(0)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  locations   WarehouseLocation[]
  stockTakes  StockTake[]
  sensors     Sensor[]

  @@unique([warehouseId, code])
  @@map("warehouse_zones")
}

model WarehouseLocation {
  id           String   @id @default(cuid())
  zoneId       String
  warehouseId  String
  name         String
  code         String
  barcode      String?  @unique
  locationType String   @default("STANDARD")
  capacity     Int      @default(0)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())

  zone          WarehouseZone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  inventory     Inventory[]
  stockMovements StockMovement[]
  stockTakeItems StockTakeItem[]
  sensors       Sensor[]
  purchaseReceipts PurchaseReceipt[]
  barcodeRecords BarcodeRecord[]

  @@unique([warehouseId, code])
  @@map("warehouse_locations")
}

// ============================================================
// 四、产品组 + 物料/规格变体
// ============================================================

model MaterialGroup {
  id          String   @id @default(cuid())
  code        String   @unique                          // 产品组编码，如 XBG（杏鲍菇）
  name        String                                    // 产品组名称，如"杏鲍菇"
  category    String?                                   // 产品分类（鲜品/干品/耗材等）
  stockCategory String?                                  // 安全库存品类 A/B/C/D（A=流通鲜菌 B=珍稀菌 C=预制冻品 D=包装耗材）
  description String?                                   // 描述
  status      String   @default("ACTIVE")               // ACTIVE/INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  materials   Material[]                                // 关联的规格变体

  @@index([code])
  @@index([name])
  @@index([category])
  @@map("material_groups")
}

model MaterialGrade {
  id            String   @id @default(cuid())
  code          String   @unique                        // 等级编码，如 T/P/S/A/B/C
  name          String                                  // 等级名称，如"特级"/"一级"/"二级"
  description   String?                                 // 等级描述
  sortOrder     Int      @default(0)                    // 排序
  status        String   @default("ACTIVE")             // ACTIVE/INACTIVE
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  materialGrades  MaterialGradeMapping[]                 // 关联的物料（通过映射表）
  salesPlanItems  SalesPlanItem[]   @relation("SalesPlanItemGrade")  // 销售计划明细引用
  purchasePlanItems  PurchasePlanItem[]   // 采购计划明细引用
  purchaseOrderItems  PurchaseOrderItem[]   // 采购订单明细引用
  salesOrderItems  SalesOrderItem[]   // 销售订单明细引用
  receiptItems  PurchaseReceiptItem[]   // 入库明细引用
  gradeStockMovements StockMovement[]   @relation("StockMovementGrade")  // 库存移动引用

  @@index([code])
  @@index([name])
  @@index([sortOrder])
  @@map("material_grades")
}

// 物料-等级关联表（多对多）
model MaterialGradeMapping {
  id          String   @id @default(cuid())
  materialId  String                                   // 物料ID
  gradeId     String                                   // 等级ID
  createdAt   DateTime @default(now())

  material    Material     @relation(fields: [materialId], references: [id], onDelete: Cascade)
  grade       MaterialGrade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([materialId, gradeId])                     // 同一物料同一等级不允许重复
  @@index([materialId])
  @@index([gradeId])
  @@map("material_grade_mappings")
}

model Material {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  spec               String?
  unit               String?                              // 基准单位（最小计量单位，所有内部计算统一用此单位）
  purchaseUnit       String?                              // 采购单位（如"斤"、"箱"），默认等于基准单位
  salesUnit          String?                              // 销售单位（如"克"、"盒"），默认等于基准单位
  purchaseConversionFactor Decimal @default(1) @db.Decimal(10, 4) // 1个采购单位=?个基准单位（如1斤=500克→系数500）
  salesConversionFactor    Decimal @default(1) @db.Decimal(10, 4) // 1个销售单位=?个基准单位（如1克=1克→系数1）
  groupId            String?                              // 所属产品组ID（可选，无组则为独立物料）
  category           String?
  shelfLifeDays      Int      @default(0)
  storageTempMin     Decimal? @db.Decimal(5, 1)
  storageTempMax     Decimal? @db.Decimal(5, 1)
  barcode            String?  @unique
  status             String   @default("ACTIVE")
  archivePurchasePrice Decimal @default(0) @db.Decimal(12, 2)
  initialPurchasePrice Decimal @default(0) @db.Decimal(12, 2) // 采购期初价，用于成本价计算
  guidePercent        Decimal  @default(30) @db.Decimal(5, 2) // 指导百分比，指导价=成本价×(1+指导百分比%)，默认30%
  unitVolume          Decimal? @db.Decimal(10, 6)              // 每基准单位体积(m³)，用于拼车容量估算
  unitWeight          Decimal? @db.Decimal(10, 3)              // 每基准单位重量(kg)，用于拼车容量估算
  purchaseLeadTime    Int      @default(0) // 采购周期(天)，从下单到收货的天数
  latestReceiptPrice Decimal  @default(0) @db.Decimal(12, 2)
  latestReceiptDate  DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  inventory          Inventory[]
  stockMovements     StockMovement[]
  stockLocks         StockLock[]
  purchasePlanItems  PurchasePlanItem[]
  purchaseReceipts   PurchaseReceipt[]
  priceLists         PriceList[]
  salesOrderItems    SalesOrderItem[]
  salesPlanItems     SalesPlanItem[]
  standardCosts      StandardCost[]
  costSnapshots      CostSnapshot[]
  batches            Batch[]
  stockTakeItems     StockTakeItem[]
  barcodeRecords     BarcodeRecord[]
  purchaserMaterials PurchaserMaterialItem[]
  purchaseOrderItems PurchaseOrderItem[]
  receiptItems       PurchaseReceiptItem[]
  shippingOrderItems ShippingOrderItem[]
  feeRecords         FeeRecord[]

  group              MaterialGroup? @relation(fields: [groupId], references: [id])

  materialGrades     MaterialGradeMapping[]             // 关联的等级（多对多）

  // 安全库存反向关系
  stockStandards     StockStandard[]
  stockLevels        StockLevel[]
  stockAlerts        StockAlert[]

  @@index([code])
  @@index([name])
  @@index([category])
  @@index([groupId])
  @@map("materials")
}

// ============================================================
// 五、客户
// ============================================================

model Customer {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  contactPerson String?
  contactPhone String?
  address       String?
  salesRepId    String?
  departmentId  String?
  creditLimit   Decimal  @default(0) @db.Decimal(14, 2)
  creditPeriod  Int      @default(30)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salesRep      Employee?          @relation("CustomerSalesRep", fields: [salesRepId], references: [id])
  department    Department?       @relation(fields: [departmentId], references: [id])
  addresses     CustomerAddress[]
  priceLists     PriceList[]
  salesOrders    SalesOrder[]
  salesPlanItems SalesPlanItem[]
  accountsReceivable AccountsReceivable[]
  shippingOrders ShippingOrder[]
  waybills      Waybill[]
  afterSales    AfterSalesRecord[]
  batchTrackings BatchTracking[]

  @@index([name])
  @@index([salesRepId])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  receiver   String?
  phone      String?
  address    String
  lng        Decimal? @db.Decimal(10, 6)  // 经度，高德坐标
  lat        Decimal? @db.Decimal(10, 6)  // 纬度，高德坐标
  isDefault Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

// ============================================================
// 六、供应商
// ============================================================

model Supplier {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  contactPerson  String?
  contactPhone   String?
  address        String?
  bankAccount    String?
  qualification  Json?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  purchasePlans    PurchasePlanItem[]
  salesPlanItems   SalesPlanItem[]
  batches          Batch[]
  accountsPayable  AccountsPayable[]
  supplierEvals    SupplierEvaluation[]
  contracts        Contract[]        @relation("SupplierContract")

  @@index([name])
  @@map("suppliers")
}

// ============================================================
// 七、库存
// ============================================================

model Inventory {
  id           String   @id @default(cuid())
  materialId   String
  warehouseId  String
  locationId   String?
  qty          Decimal  @default(0) @db.Decimal(12, 2)
  lockedQty    Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt    DateTime @updatedAt

  material   Material   @relation(fields: [materialId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  location   WarehouseLocation? @relation(fields: [locationId], references: [id])

  @@unique([materialId, warehouseId])
  @@map("inventory")
}

// ============================================================
// 八、采购管理
// ============================================================

model PurchasePlan {
  id            String    @id @default(cuid())
  planNo        String    @unique
  title         String
  planType      String    @default("MONTHLY")
  priceDate      DateTime?
  periodStart   DateTime?
  periodEnd     DateTime?
  departmentId  String?
  status        String    @default("DRAFT")
  totalBudget   Decimal    @default(0) @db.Decimal(14, 2)
  creatorId     String
  approverId    String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  parentPlanId  String?
  assigneeId    String?
  remark        String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  department  Department?       @relation(fields: [departmentId], references: [id])
  creator     Employee          @relation("PurchasePlanCreator", fields: [creatorId], references: [id])
  approver    Employee?        @relation("PurchasePlanApprover", fields: [approverId], references: [id])
  parentPlan  PurchasePlan?     @relation("PlanParentChild", fields: [parentPlanId], references: [id])
  childPlans  PurchasePlan[]    @relation("PlanParentChild")
  assignee    User?             @relation("PlanAssignee", fields: [assigneeId], references: [id])
  items       PurchasePlanItem[]
  purchaseOrders PurchaseOrder[]

  @@index([status])
  @@index([periodEnd])
  @@index([parentPlanId])
  @@index([assigneeId])
  @@map("purchase_plans")
}

model PurchasePlanItem {
  id               String    @id @default(cuid())
  planId           String
  materialId       String
  planQty          Int        @default(0)
  unit             String?
  budgetUnitPrice  Decimal    @default(0) @db.Decimal(12, 2)
  budgetTotal      Decimal    @default(0) @db.Decimal(12, 2)
  expectedDate     DateTime?
  orderedQty       Int        @default(0)
  receivedQty      Int        @default(0)
  supplierId       String?
  unitPrice        Decimal    @default(0) @db.Decimal(12, 2)  // 采购员填写的实际单价
  actualQty        Int        @default(0)                            // 采购员填写的实际采购数量
  demandAggNo      String?   @map("demand_agg_no")
  remark           String?   @db.Text
  suggestionNo     String?   @map("suggestion_no")
  forwarded        Boolean   @default(false)
  gradeId          String?   @map("grade_id")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  plan      PurchasePlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  material  Material       @relation(fields: [materialId], references: [id])
  supplier  Supplier?      @relation(fields: [supplierId], references: [id])
  grade     MaterialGrade? @relation(fields: [gradeId], references: [id])
  orderItems PurchaseOrderItem[]

  @@index([planId])
  @@index([materialId])
  @@map("purchase_plan_items")
}

model PurchaseOrder {
  id                 String    @id @default(cuid())
  orderNo            String    @unique
  supplierId         String
  purchasePlanId     String?
  purchasePlanItemId String?
  warehouseId        String
  orderDate          DateTime
  expectedDate       DateTime?
  receiptStatus      String    @default("PENDING")
  receivedQty        Int       @default(0)
  unitPrice          Decimal   @default(0) @db.Decimal(12, 2)
  taxRate            Decimal   @default(0) @db.Decimal(5, 2)
  qty                Int
  totalAmount        Decimal   @default(0) @db.Decimal(14, 2)
  taxAmount          Decimal   @default(0) @db.Decimal(14, 2)
  grandTotal         Decimal   @default(0) @db.Decimal(14, 2)
  contractId         String?
  status             String    @default("PENDING")
  buyerId            String?
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  supplier          Supplier        @relation(fields: [supplierId], references: [id])
  purchasePlan      PurchasePlan?   @relation(fields: [purchasePlanId], references: [id])
  warehouse         Warehouse       @relation(fields: [warehouseId], references: [id])
  buyer             Employee?       @relation("PurchaseBuyer", fields: [buyerId], references: [id])
  contract          Contract?       @relation(fields: [contractId], references: [id])
  receipts          PurchaseReceipt[]
  items             PurchaseOrderItem[]

  @@index([supplierId])
  @@index([status])
  @@index([purchasePlanId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id           String   @id @default(cuid())
  orderId      String
  planItemId   String?
  materialId   String
  qty          Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  taxRate      Decimal  @default(0) @db.Decimal(5, 2)
  totalAmount  Decimal  @default(0) @db.Decimal(14, 2)
  taxAmount    Decimal  @default(0) @db.Decimal(14, 2)
  grandTotal   Decimal  @default(0) @db.Decimal(14, 2)
  remark       String?  @db.Text
  gradeId      String?  @map("grade_id")
  createdAt    DateTime @default(now())

  order     PurchaseOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  planItem  PurchasePlanItem? @relation(fields: [planItemId], references: [id])
  material  Material          @relation(fields: [materialId], references: [id])
  grade     MaterialGrade?    @relation(fields: [gradeId], references: [id])
  receiptItem PurchaseReceiptItem?

  @@index([orderId])
  @@index([planItemId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id               String    @id @default(cuid())
  receiptNo        String    @unique
  purchaseOrderId  String
  warehouseId      String
  locationId       String?
  materialId       String?
  receiptDate      DateTime?
  receivedQty      Int
  unitPrice        Decimal   @db.Decimal(12, 2)
  taxRate          Decimal   @default(0) @db.Decimal(5, 2)
  totalAmount      Decimal   @default(0) @db.Decimal(14, 2)
  batchId          String?   @unique
  inspectorId      String?
  qcResult         String    @default("PASS")
  qcAttachment     String?
  status           String    @default("CONFIRMED")
  remark           String?   @db.Text
  createdAt        DateTime  @default(now())

  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  location         WarehouseLocation? @relation(fields: [locationId], references: [id])
  material         Material?      @relation(fields: [materialId], references: [id])
  batch            Batch?         @relation("ReceiptBatch", fields: [batchId], references: [id])
  inspector        Employee?      @relation("PurchaseInspector", fields: [inspectorId], references: [id])
  items            PurchaseReceiptItem[]

  @@index([purchaseOrderId])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id           String   @id @default(cuid())
  receiptId    String
  orderItemId  String?  @unique
  materialId   String
  receivedQty  Int      @default(0)
  unitPrice    Decimal  @db.Decimal(12, 2)
  taxRate      Decimal  @default(0) @db.Decimal(5, 2)
  totalAmount  Decimal  @default(0) @db.Decimal(14, 2)
  qcResult     String   @default("PENDING")
  qcAttachment String?
  batchId      String?  @unique
  gradeId      String?  @map("grade_id")
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  receipt      PurchaseReceipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  orderItem    PurchaseOrderItem?  @relation(fields: [orderItemId], references: [id])
  material     Material            @relation(fields: [materialId], references: [id])
  grade        MaterialGrade?      @relation(fields: [gradeId], references: [id])
  batch        Batch?              @relation("ReceiptItemBatch", fields: [batchId], references: [id])

  @@index([receiptId])
  @@index([materialId])
  @@map("purchase_receipt_items")
}

// ============================================================
// 九、销售管理
// ============================================================

model SalesPlan {
  id              String    @id @default(cuid())
  planNo          String    @unique
  title           String
  planType        String    @default("MONTHLY")
  periodStart     DateTime
  periodEnd       DateTime
  salesRepId      String
  departmentId    String?
  targetAmount    Decimal   @default(0) @db.Decimal(14, 2)
  actualAmount    Decimal   @default(0) @db.Decimal(14, 2)
  completionRate  Decimal   @default(0) @db.Decimal(5, 2)
  status          String    @default("DRAFT")
  approverId      String?
  approvedAt      DateTime?
  remark          String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  salesRep      Employee          @relation("SalesPlanRep", fields: [salesRepId], references: [id])
  department    Department?       @relation(fields: [departmentId], references: [id])
  approver      Employee?         @relation("SalesPlanApprover", fields: [approverId], references: [id])
  items         SalesPlanItem[]
  salesOrders   SalesOrder[]

  @@index([salesRepId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("sales_plans")
}

model SalesPlanItem {
  id           String    @id @default(cuid())
  salesPlanId  String
  customerId   String?
  materialId   String
  supplierId   String?
